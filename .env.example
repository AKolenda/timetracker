# Database Provider — "supabase" (hosted) or "local" (future MariaDB support)
NEXT_PUBLIC_DB_PROVIDER=supabase

# Supabase — create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend — optional, for sending invoice emails (https://resend.com)
RESEND_API_KEY=re_your_api_key
